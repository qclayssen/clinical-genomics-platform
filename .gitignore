# Nextflow
.nextflow/
.nextflow.log*
work/
work_*/
results/
pipeline/assets/reference/*
pipeline/assets/truth/*
pipeline/assets/testdata/*
!pipeline/assets/reference/.gitkeep
!pipeline/assets/truth/.gitkeep
!pipeline/assets/testdata/.gitkeep

# Large data / models
*.fastq.gz
*.bam
*.bai
*.vcf.gz
*.tbi
*.fa
*.fa.*
ai-report/checkpoints/
ai-report/data/*.jsonl

# ...but DO commit the tiny placeholder test data + curated ML sample (small, needed for CI)
!pipeline/assets/testdata/tiny_ref.fa
!pipeline/assets/testdata/tiny_truth.vcf.gz
!pipeline/assets/testdata/tiny_truth.bed
!pipeline/assets/testdata/*.fastq.gz
!ai-report/data/report_pairs.sample.jsonl

# CDK
infra/node_modules/
infra/cdk.out/
infra/**/*.js
infra/**/*.d.ts
!infra/jest.config.js

# Python
__pycache__/
*.pyc
venv/
.venv/

# OS
.DS_Store
