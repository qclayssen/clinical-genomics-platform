/*
 * AWS profile — run the same pipeline on AWS Batch, writing to the S3 data lake.
 *
 * Bucket / queue names come from the CDK stack outputs (infra/). Populate via env:
 *   export CGP_S3_BUCKET=...   CGP_BATCH_QUEUE=...   CGP_DB_URL=...
 *   nextflow run main.nf -profile aws
 */

params {
    db_ingest = true
    outdir    = "s3://${System.getenv('CGP_S3_BUCKET')}/results"
}

process {
    executor  = 'awsbatch'
    queue     = System.getenv('CGP_BATCH_QUEUE')
    container = 'public.ecr.aws/lts/ubuntu:22.04'   // per-process containers override this

    withLabel:process_low    { cpus = 1; memory = 2.GB }
    withLabel:process_medium { cpus = 4; memory = 8.GB }
    withLabel:process_high   { cpus = 8; memory = 16.GB }
}

aws {
    region = System.getenv('AWS_REGION') ?: 'ap-southeast-2'
    batch {
        cliPath          = '/usr/local/bin/aws'
        maxParallelTransfers = 4
        volumes          = '/scratch'
    }
}

workDir = "s3://${System.getenv('CGP_S3_BUCKET')}/work"
