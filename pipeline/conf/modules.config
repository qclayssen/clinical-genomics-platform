/*
 * modules.config — per-process publishDir (nf-core convention)
 *
 * The individual module `.nf` files no longer hardcode `publishDir`; instead each
 * process's output routing lives here, keyed by `withName:`. This is the nf-core
 * pattern: modules stay portable and reusable, and where results land is a
 * pipeline-level configuration concern. Path closures reference the task's `meta`
 * map, which is in scope when the directive is evaluated.
 */

process {

    withName: 'FASTP' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/qc/fastp" },
            mode: 'copy'
        ]
    }

    withName: 'FASTQC' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/qc/fastqc" },
            mode: 'copy'
        ]
    }

    withName: 'MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: 'copy'
        ]
    }

    withName: 'BWAMEM2_ALIGN' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/align" },
            mode: 'copy',
            pattern: '*.log'
        ]
    }

    withName: 'MARKDUPLICATES' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/align" },
            mode: 'copy'
        ]
    }

    withName: 'HAPLOTYPECALLER' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variants" },
            mode: 'copy'
        ]
    }

    withName: 'DEEPVARIANT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/variants" },
            mode: 'copy'
        ]
    }

    withName: 'HAPPY_BENCHMARK' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/validation" },
            mode: 'copy'
        ]
    }

    withName: 'JSON_METRICS' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/export" },
            mode: 'copy'
        ]
    }

    withName: 'PARQUET_EXPORT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/export" },
            mode: 'copy'
        ]
    }

    // DB_INGEST intentionally has no publishDir — its only output is a log kept in work/.
    // Collated software versions are published by the collectFile operator in main.nf
    // (storeDir: pipeline_info), so they need no withName block here.
}
