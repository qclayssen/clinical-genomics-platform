/*
 * Test profile — tiny subset that runs on a laptop.
 *
 *   nextflow run main.nf -profile test,docker -stub   # DAG only, no tools needed
 *   nextflow run main.nf -profile test,docker          # real run on chr20 subset
 *
 * Inputs are staged by scripts/fetch_testdata.sh (GIAB HG002 chr20).
 */

params {
    input     = "${projectDir}/assets/samplesheet.test.csv"
    intervals = 'chr20:1000000-2000000'   // 1 Mb window keeps the full run minutes-long

    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '2.h'
}

process {
    withLabel:process_low    { cpus = 1; memory = 2.GB }
    withLabel:process_medium { cpus = 2; memory = 4.GB }
    withLabel:process_high   { cpus = 4; memory = 8.GB }
}
