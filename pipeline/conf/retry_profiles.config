/*
 * retry_profiles.config — Attempt-dependent fastp parameters for QC retry profiles
 *
 * Each retry attempt uses progressively stricter filtering parameters to
 * improve sample quality at the cost of read yield. This enables self-healing:
 * if a sample fails QC on the first pass, stricter trimming often recovers it.
 *
 * Exit code convention:
 *   42 = QC soft fail (retryable — fastp output failed QC thresholds)
 *   43 = QC hard fail (not retryable — fundamental sample quality issue)
 *
 * Profiles align with pipeline/conf/qc_thresholds.yaml retry_profiles section.
 */

params {
    // ── Retry profile parameters (keyed by attempt number) ─────────────────
    // Attempt 1: Default parameters (standard quality filtering)
    fastp_phred_1       = 15
    fastp_length_1      = 50
    fastp_poly_g_1      = false
    fastp_cut_front_1   = false
    fastp_cut_tail_1    = false

    // Attempt 2: Stricter quality and length filters
    fastp_phred_2       = 20
    fastp_length_2      = 60
    fastp_poly_g_2      = true
    fastp_cut_front_2   = false
    fastp_cut_tail_2    = false

    // Attempt 3: Aggressive trimming with sliding window
    fastp_phred_3       = 25
    fastp_length_3      = 75
    fastp_poly_g_3      = true
    fastp_cut_front_3   = true
    fastp_cut_tail_3    = true
    fastp_cut_window_3  = 4
    fastp_cut_mean_q_3  = 20
}

process {
    // Extend errorStrategy to include exit code 42 (QC soft fail → retryable)
    // Exit code 43 (QC hard fail) is NOT retryable.
    withName: 'FASTP' {
        errorStrategy = { task.exitStatus in [143,137,104,134,139,42] ? 'retry' : 'finish' }
        maxRetries    = 3
    }
}
