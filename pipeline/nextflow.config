/*
 * Base configuration — Clinical Genomics Insight Platform
 */

manifest {
    name            = 'clinical-genomics-platform'
    author          = 'Quentin Clayssen'
    description      = 'Germline SNV pipeline benchmarked against GIAB truth sets'
    version         = '0.3.0'
    nextflowVersion = '>=23.10.0'
    mainScript      = 'main.nf'
}

params {
    // ── Inputs ─────────────────────────────────────────────────────────────
    input          = "${projectDir}/assets/samplesheet.csv"
    outdir         = "${launchDir}/results"

    // ── Reference (GRCh38, chr20 subset for the test/scope) ────────────────
    reference       = "${projectDir}/assets/reference/GRCh38_chr20.fa"
    reference_build = 'GRCh38.p14'

    // ── Truth set (GIAB HG002 v4.2.1) ──────────────────────────────────────
    truth_vcf     = "${projectDir}/assets/truth/HG002_GRCh38_chr20_v4.2.1.vcf.gz"
    truth_bed     = "${projectDir}/assets/truth/HG002_GRCh38_chr20_v4.2.1.bed"
    truth_version = 'GIAB-v4.2.1'

    // ── Behaviour ──────────────────────────────────────────────────────────
    caller     = 'gatk'          // 'gatk' | 'deepvariant'
    db_ingest  = false           // set true (or -profile aws) to write to Postgres
    db_url     = System.getenv('CGP_DB_URL') ?: 'postgresql://cgp:cgp@localhost:5432/cgp'

    max_cpus   = 8
    max_memory = '16.GB'
    max_time   = '8.h'
}

process {
    cpus   = { check_max(2    * task.attempt, 'cpus'  ) }
    memory = { check_max(4.GB * task.attempt, 'memory') }
    time   = { check_max(2.h  * task.attempt, 'time'  ) }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
    cache         = 'lenient'      // provenance-friendly: reuse only on identical inputs
}

profiles {
    docker  { docker.enabled = true;  docker.runOptions = '-u $(id -u):$(id -g)' }
    test    { includeConfig 'conf/test.config' }
    aws     { includeConfig 'conf/aws.config'  }
}

// Provenance: capture full run metadata alongside every set of results
timeline { enabled = true; file = "${params.outdir}/provenance/timeline.html" }
report   { enabled = true; file = "${params.outdir}/provenance/report.html"   }
trace    { enabled = true; file = "${params.outdir}/provenance/trace.txt"     }
dag      { enabled = true; file = "${params.outdir}/provenance/dag.html"      }

def check_max(obj, type) {
    if (type == 'memory')  return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1 ? params.max_memory as nextflow.util.MemoryUnit : obj
    if (type == 'time')    return obj.compareTo(params.max_time   as nextflow.util.Duration)   == 1 ? params.max_time   as nextflow.util.Duration   : obj
    if (type == 'cpus')    return Math.min(obj as int, params.max_cpus as int)
    return obj
}
