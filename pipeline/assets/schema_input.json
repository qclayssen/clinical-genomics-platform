{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Clinical Genomics Insight Platform — input sample sheet",
  "description": "One paired-end WGS sample per row",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "sample":  { "type": "string", "pattern": "^\\S+$", "description": "Unique sample identifier" },
      "fastq_1": { "type": "string", "pattern": "^\\S+\\.f(ast)?q\\.gz$", "description": "Path/URI to R1 gzipped FASTQ" },
      "fastq_2": { "type": "string", "pattern": "^\\S+\\.f(ast)?q\\.gz$", "description": "Path/URI to R2 gzipped FASTQ" }
    },
    "required": ["sample", "fastq_1", "fastq_2"]
  }
}
